define accesspolicy ZAC_AUDITING_ASPECT_DNAVAS {
    @EndUserText.label: 'Access Control  Auditing Aspect'
    define aspect ZAC_AUDITING_ASPECT_DNAVAS as
        select from zcds_auditing_aspect_dnavas with user element CreatedBy
            {
                CreatedBy,
                CustomerName
            }
}